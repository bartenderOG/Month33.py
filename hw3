import asyncio
import logging
from aiogram import Bot, Dispatcher, Router, F
from aiogram.types import (
    Message, 
    CallbackQuery,
    ReplyKeyboardMarkup, 
    KeyboardButton, 
    InlineKeyboardMarkup, 
    InlineKeyboardButton
)
from aiogram.filters import CommandStart, Command

BOT_TOKEN = ""

bot = Bot(token=BOT_TOKEN)
dp = Dispatcher()
router = Router()

reply_languages = ReplyKeyboardMarkup(
    keyboard=[
        [
            KeyboardButton(text="Python"),
            KeyboardButton(text="JS"),
            KeyboardButton(text="C#")
        ]
    ],
    resize_keyboard=True,
    input_field_placeholder="Выберите язык программирования"
)

inline_help = InlineKeyboardMarkup(
    inline_keyboard=[
        [InlineKeyboardButton(text="Документация Python", url="https://docs.python.org/3/")],
        [InlineKeyboardButton(text="Документация JS", url="https://developer.mozilla.org/ru/docs/Web/JavaScript")],
        [InlineKeyboardButton(text="Документация C#", url="https://learn.microsoft.com/ru-ru/dotnet/csharp/")],
        [InlineKeyboardButton(text="Начать обучение", callback_data="start_learning")]
    ]
)

@router.message(CommandStart())
async def cmd_start(message: Message):
    await message.answer(
        f"Привет, {message.from_user.first_name}! Я твой первый бот.\n"
        f"Пожалуйста, выберите язык программирования для изучения:",
        reply_markup=reply_languages
    )

@router.message(Command('about'))
async def cmd_about(message: Message):
    await message.answer(
        'Привет, я бот, созданный по велению Омниссии 🤖'
    )

@router.message(Command('help'))
async def cmd_help(message: Message):
    await message.answer(
        'список команд:\n'
        '/start - приветствие\n'
        '/help - список команд \n'
        '/about - о себе\n\n'
        'Также вы можете использовать кнопки ниже для перехода к документации:',
        reply_markup=inline_help
    )

@router.message(F.text == "Python")
async def info_python(message: Message):
    await message.answer("🐍 Python — это высокоуровневый язык программирования общего назначения. Он очень прост в изучении, имеет чистый синтаксис и безумно популярен в сферах Web-разработки, Data Science, машинного обучения и автоматизации.")

@router.message(F.text == "JS")
async def info_js(message: Message):
    await message.answer("🌐 JavaScript (JS) — это мультипарадигменный язык, который буквально управляет современным интернетом. На нем пишется интерактив для сайтов (Frontend), а благодаря Node.js — и серверная логика (Backend).")

@router.message(F.text == "C#")
async def info_csharp(message: Message):
    await message.answer("🎮 C# — мощный объектно-ориентированный язык от компании Microsoft. Широко применяется в разработке масштабного корпоративного софта, мобильных приложений и, конечно же, в игровой индустрии на движке Unity.")

@router.callback_query(F.data == "start_learning")
async def process_start_learning(callback: CallbackQuery):
    await callback.answer(
        text="Начинаем обучение! Приготовьтесь к кодингу. 🚀",
        show_alert=True
    )

async def main():
    logging.basicConfig(level=logging.INFO)
    dp.include_router(router)
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())